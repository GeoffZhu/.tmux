#!/usr/bin/env bash
set -Eeuo pipefail

source_dir="$HOME/.tmux/extensions/bytedance.vscode-tmux-cleaner-0.0.1"
trae_target="$HOME/.trae-cn/extensions/bytedance.vscode-tmux-cleaner-0.0.1"
vscode_target="$HOME/.vscode/extensions/bytedance.vscode-tmux-cleaner-0.0.1"

ensure_link() {
  local target="$1"

  mkdir -p "$(dirname "$target")"

  if [ -L "$target" ] && [ "$(readlink "$target")" = "$source_dir" ]; then
    return
  fi

  if [ -e "$target" ] && [ ! -L "$target" ]; then
    mv "$target" "${target}.bak.$(date +%Y%m%d%H%M%S)"
  else
    rm -f "$target"
  fi

  ln -s "$source_dir" "$target"
}

ensure_link "$trae_target"
ensure_link "$vscode_target"

echo "linked:"
echo "  $trae_target -> $source_dir"
echo "  $vscode_target -> $source_dir"
